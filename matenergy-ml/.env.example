# ============================================================
# MatEnergy-ML Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true

# --- Database (PostgreSQL) ---
POSTGRES_USER=matenergy
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=matenergy_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Security / Auth ---
SECRET_KEY=change_me_to_a_random_64_char_hex_string
JWT_SECRET_KEY=change_me_to_another_random_64_char_hex_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- External Materials Databases APIs ---
MATERIALS_PROJECT_API_KEY=your_materials_project_api_key_here
JARVIS_API_KEY=your_jarvis_api_key_here
NOMAD_TOKEN=your_nomad_token_here

# --- Upload / Dataset Limits ---
MAX_UPLOAD_SIZE_MB=50
MAX_ROWS_PER_DATASET=100000

# --- ML / DFT Thresholds ---
# Energy above hull threshold for thermodynamic stability (eV/atom)
STABILITY_THRESHOLD_EV=0.05

# --- Storage Paths ---
ARTIFACT_STORAGE_PATH=./artifacts
DATA_STORAGE_PATH=./data

# --- Redis (optional — rate limiting) ---
# Uncomment and set if using Redis for rate limiting
# REDIS_URL=redis://redis:6379/0
